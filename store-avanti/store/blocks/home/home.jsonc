  //BANNER SEO
  "flex-layout.row#imagen-central": {
    "title": "Banner Central",
    "props": {
      "blockClass": [
        "central"
      ]
    },
    "children": [
      "flex-layout.col#vacio",
      "flex-layout.col#texto-seo"
    ]
  },
  "flex-layout.col#vacio": {
    "props": {
      "blockClass": "vacio"
    }
  },
  "flex-layout.col#texto-seo": {
    "props": {
      "blockClass": "contenido"
    },
    "children": [
      "info-card#home"
    ]
  },
  "info-card#home": {
    "title": "Texto-InfoCard",
    "props": {
      "id": "info-card-home",
      "isFullModeStyle": true,
      "textPosition": "right",
      "imageUrl": "",
      "headline": " LOREM IPSUM",
      "subhead": "Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea.",
      "callToActionText": "Lorem ipsum",
      "callToActionUrl": "/sale/d",
      "blockClass": "info-card-home",
      "textAlignment": "left"
    }
  },
  /*NEW SALE*/
  "flex-layout.row#new-sale": {
    "title": "New Sales",
    "props": {
      "blockClass": [
        "new-sale",
        "grid1252"
      ]
    },
    "children": [
      "image#new1",
      "image#new2"
    ]
  },
  "image#new1": {
    "title": "Imagen 1",
    "props": {
      "src": "assets/img/newin.png",
      "maxHeight": "569px",
      "maxWidth": "616px",
      "blockClass": "new1"
    }
  },
  "image#new2": {
    "title": "Imagen 2",
    "props": {
      "src": "assets/img/sale.png",
      "maxHeight": "569px",
      "maxWidth": "616px",
      "blockClass": "new2"
    }
  },
  //BANNER
  "flex-layout.row#title-banner": {
    "props": {
      "blockClass": [
        "title-banner",
        "grid1252"
      ]
    },
    "children": [
      "rich-text#title-banner"
    ]
  },
  "rich-text#title-banner": {
    "title": "Titulo Banner",
    "props": {
      "blockClass": "banner",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "text": "# TITULO DE BANNERS"
    }
  },
  "flex-layout.row#banner1": {
    "title": "Banner 1",
    "props": {
      "blockClass": [
        "banner1",
        "grid1252"
      ]
    },
    "children": [
      "image#electronica",
      "image#ropa",
      "image#accesorio"
    ]
  },
  "image#electronica": {
    "title": "Electronica",
    "props": {
      "src": "assets/img/reloj.png",
      "maxHeight": "300px",
      "maxWidth": "390x",
      "blockClass": "electronica"
    }
  },
  "image#ropa": {
    "title": "Roupa",
    "props": {
      "src": "assets/img/remera.png",
      "maxHeight": "300px",
      "maxWidth": "390px",
      "blockClass": "ropa"
    }
  },
  "image#accesorio": {
    "title": "Accesorios",
    "props": {
      "src": "assets/img/anteojo.png",
      "maxHeight": "300px",
      "maxWidth": "390px",
      "blockClass": "accesorio"
    }
  },
  "flex-layout.row#banner2": {
    "props": {
      "blockClass": [
        "banner2",
        "grid1252"
      ]
    },
    "children": [
      "image#perfume",
      "image#cosmetico",
      "image#calzado"
    ]
  },
  "image#perfume": {
    "title": "Perfume",
    "props": {
      "src": "assets/img/perfume2.png",
      "maxHeight": "300px",
      "maxWidth": "390x",
      "blockClass": "perfume"
    }
  },
  "image#cosmetico": {
    "title": "Cosmeticos",
    "props": {
      "src": "assets/img/perfume1.png",
      "maxHeight": "300px",
      "maxWidth": "390px",
      "blockClass": "cosmetico"
    }
  },
  "image#calzado": {
    "title": "Calçado",
    "props": {
      "src": "assets/img/zapatilla.png",
      "maxHeight": "300px",
      "maxWidth": "390px",
      "blockClass": "calzado"
    }
  },
  //VITRINE
  "flex-layout.row#vitrine1": {
    "title": "Vitrine 1",
    "props": {
      "blockClass": [
        "vitrine1",
        "grid1252"
      ]
    },
    "children": [
      "rich-text#title-vitrine1"
    ]
  },
  "rich-text#title-vitrine1": {
    "title": "Titulo vitrine 1",
    "props": {
      "blockClass": "vitrine1",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "text": "# VITRINE 1"
    }
  },
  "flex-layout.row#vitrine-slider1": {
    "title": "Vitrine Slider",
    "props": {
      "blockClass": [
        "row-slider1",
        "grid1252"
      ]
    },
    "children": [
      "list-context.product-list#vitrine-slider1"
    ]
  },
  "list-context.product-list#vitrine-slider1": {
    "blocks": [
      "product-summary.shelf"
    ],
    "children": [
      "slider-layout#vitrine-slider1"
    ],
    "props": {
      "orderBy": "OrderByTopSaleDESC"
    }
  },
  "slider-layout#vitrine-slider1": {
    "title": "Slider ",
    "props": {
      "itemsPerPage": {
        "desktop": 4,
        "tablet": 1,
        "phone": 1
      },
      "infinite": true,
      "showNavigationArrows": "always",
      "blockClass": "carousel",
      "showPaginationDots": "never",
      "autoplay": {
        "timeout": 3000,
        "stopOnHover": true
      }
    }
  },
  //IMAGEN CAMIONSITO
  "flex-layout.row#banner-sale": {
    "title": "Banner Frete",
    "props": {
      "blockClass": [
        "banner-sale",
        "grid1252"
      ]
    },
    "children": [
      "image#banner-sale"
    ]
  },
  "image#banner-sale": {
    "title": "Imagem Banner Frete",
    "props": {
      "src": "assets/img/banner-sale.png"
    }
  },
