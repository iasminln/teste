      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "text": "# VITRINE 2"
    }
  },
  "flex-layout.row#vitrine-slider2": {
    "title": "Slider Vitrine 2",
    "props": {
      "blockClass": [
        "row-slider2",
        "grid1252"
      ]
    },
    "children": [
      "list-context.product-list#vitrine-slider2"
    ]
  },
  "list-context.product-list#vitrine-slider2": {
    "blocks": [
      "product-summary.shelf"
    ],
    "children": [
      "slider-layout#vitrine-slider2"
    ],
    "props": {
      "orderBy": "OrderByTopSaleDESC"
    }
  },
  "slider-layout#vitrine-slider2": {
    "title": "Slider ",
    "props": {
      "itemsPerPage": {
        "desktop": 4,
        "tablet": 2,
        "phone": 1
      },
      "infinite": true,
      "showNavigationArrows": "always",
      "blockClass": "carousel",
      "showPaginationDots": "never",
      "autoplay": {
        "timeout": 3000,
        "stopOnHover": true
      }
    }
  }
