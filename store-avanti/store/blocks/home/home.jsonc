{
  "store.home": {
    "blocks": [
      "responsive-layout.desktop",
      "responsive-layout.phone",
      "responsive-layout.tablet"
    ]
  },
  "responsive-layout.desktop": {
    "children": [

      "product-modal#desktop",

      "flex-layout.row#img-central",
      "__fold__.experimentalLazyAssets",
      "flex-layout.row#deals",
      "flex-layout.row#rich-texto",
      "flex-layout.row#slider",
      "flex-layout.row#imagen-central",
      "flex-layout.row#new-sale",
      "flex-layout.row#title-banner",
      "flex-layout.row#banner1",
      "flex-layout.row#banner2",
      "flex-layout.row#vitrine1",
      "flex-layout.row#vitrine-slider1",
      "flex-layout.row#banner-sale",
      "flex-layout.row#vitrine2",
      "flex-layout.row#vitrine-slider2"
    ]
  },
  //SLIDER DEL COMIENZO
  "flex-layout.row#img-central": {
    "title": "Banner central",
    "props": {
      "blockClass": "grid1252"
    },
    "children": [
      "list-context.image-list#demo"
    ]
  },
  "list-context.image-list#demo": {
    "children": [
      "slider-layout#demo-images"
    ],
    "props": {
      "height": 720,
      "images": [
        {
          "image": "assets/img/hero.png",
          "mobileImage": "assets/img/hero-mobile.png"
        },
        {
          "image": "assets/img/hero.png",
          "mobileImage": "assets/img/hero-mobile.png"
        }
      ]
    }
  },
  "slider-layout#demo-images": {
    "props": {
      "itemsPerPage": {
        "desktop": 1,
        "tablet": 1,
        "phone": 1
      },
      "infinite": true,
      "showNavigationArrows": "Never",
      "blockClass": "carousel"
    }
  },
  //DEPARTAMENTOS
  "flex-layout.row#rich-texto": {
    "title": "Titulo Departamentos",
    "props": {
      "blockClass": "grid1252"
    },
    "children": [
      "rich-text#shelf-title"
    ]
  },
  "rich-text#shelf-title": {
    "title": "Texto",
    "props": {
      "text": "# TODOS OS DEPARTAMENTOS",
      "blockClass": "shelfTitle",
      "font": "OpenSans-Bold"
    }
  },
  "flex-layout.row#slider": {
    "title": "Slider Departamentos",
    "props": {
      "blockClass": [
        "slider-departamentos",
        "grid1252"
      ]
    },
    "children": [
      "slider-layout#departamentos"
    ]
  },
  "slider-layout#departamentos": {
    "props": {
      "itemsPerPage": {
        "desktop": 8,
        "tablet": 5,
        "phone": 3
      },
      "infinite": true,
      "showNavigationArrows": "always",
      "centerMode": "disabled",
      "showPaginationDots": "never",
      "blockClass": "slider-departments-container"
    },
    "children": [
      "flex-layout.col#dpto1",
      "flex-layout.col#dpto2",
      "flex-layout.col#dpto3",
      "flex-layout.col#dpto4",
      "flex-layout.col#dpto5",
      "flex-layout.col#dpto6",
      "flex-layout.col#dpto7",
      "flex-layout.col#dpto8"
    ]
  },
  "flex-layout.col#dpto1": {
    "props": {
      "blockClass": [
        "dpto1"
      ]
    },
    "children": [
      "flex-layout.row#image-dpto1",
      "flex-layout.row#text-dpto1"
    ]
  },
  "flex-layout.row#image-dpto1": {
    "props": {
      "blockClass": "grid1252"
    },
    "children": [
      "image#dpto1"
    ]
  },
  "image#dpto1": {
    "props": {
      "src": "assets/img/dpto1.png"
    }
  },
  "flex-layout.row#text-dpto1": {
    "props": {
      "blockClass": "grid1252",
      "textAlignment": "CENTER",
      "textPosition": "CENTER"
    },
    "children": [
      "rich-text#dpto1"
    ]
  },
  "rich-text#dpto1": {
    "props": {
      "text": "Departamento 1",
      "blockClass": "departamento1"
    }
  },
